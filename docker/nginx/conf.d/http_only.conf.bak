# Rename to tradeos.conf for initial certbot verification.
# Replace with tradeos.conf after cert is obtained.

server {
    listen 80;
    server_name srv1332119.hstgr.cloud;

    # Certbot ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Redirect all HTTP to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}
