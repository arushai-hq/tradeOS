# TEMPLATE ONLY — copy to secrets.yaml and fill in values
# secrets.yaml is in .gitignore and will NEVER be committed
#
# To create your secrets.yaml:
#   cp config/secrets.yaml.template config/secrets.yaml
#   Then fill in all values below.
#
# Zerodha token expires at midnight IST every day.
# Run: python scripts/zerodha_auth.py each morning to regenerate.

zerodha:
  api_key: "YOUR_API_KEY"
  api_secret: "YOUR_API_SECRET"
  access_token: ""         # Generated daily via login flow
  token_date: ""           # Today's date in YYYY-MM-DD format, e.g. "2026-03-06"

telegram:
  trading:
    bot_token: ""          # From @BotFather. S1 trading signals, fills, exits, heartbeat, system alerts.
    chat_id: ""            # Telegram chat/group ID for trading channel. Leave empty to disable.
  hawk:
    bot_token: ""          # From @BotFather. HAWK AI watchlist picks and morning updates.
    chat_id: ""            # Telegram chat/group ID for HAWK channel. Leave empty to disable.

anthropic:
  api_key: ""              # Anthropic API key for HAWK LLM calls. Get from console.anthropic.com.
